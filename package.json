{
    "name": "link",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "start": "vite --host 127.0.0.1",
        "build": "vite build",
        "test": "vitest",
        "preview": "vite preview",
        "format": "biome format --write .",
        "lint": "biome lint .",
        "check": "biome check .",
        "codegen": "graphql-codegen --watch",
        "cypress": "npx cypress open",
        "cypress-coverage": "rm -rf coverage .nyc_output ; npx cypress run ; npx nyc report --check-coverage --lines 80",
        "backend": "venv/bin/flask --app backend.app run --port 8000 --debug",
        "dev": "concurrently npm:start npm:test npm:codegen",
        "all": "concurrently npm:backend npm:start npm:test npm:codegen"
    },
    "dependencies": {
        "@apollo/client": "^4.2.4",
        "@fortawesome/free-solid-svg-icons": "^7.3.0",
        "@shish2k/react-faicon": "^0.1.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-router-dom": "^7.18.1",
        "react-tooltip": "^6.0.8",
        "usehooks-ts": "^3.1.1"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.1",
        "@graphql-codegen/cli": "^7.1.3",
        "@graphql-codegen/client-preset": "^6.0.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "concurrently": "^10.0.3",
        "cypress": "^15.18.0",
        "sass": "^1.101.0",
        "typescript": "^6.0",
        "vite": "^8.1",
        "vitest": "^4.1.9"
    }
}
